# Use MySQL on GoDaddy cPanel, PostgreSQL/Supabase, or SQLite locally.
# MySQL example: mysql://USER:PASSWORD@HOST:3306/DBNAME
# PostgreSQL example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL="file:./dev.db"

# Get a personal key from api.data.gov. DEMO_KEY is okay only for quick testing.
GSA_API_KEY="DEMO_KEY"

# Protect the ingestion endpoint so random users cannot trigger it.
INGEST_SECRET="change-this-long-random-secret"
NEXT_PUBLIC_SITE_NAME="Government Vehicle Auction Feed"
