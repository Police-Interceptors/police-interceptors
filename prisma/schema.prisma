generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AuctionListing {
  id              String   @id @default(cuid())
  source          String
  sourceAuctionId String
  sourceLotId     String?
  title           String
  description     String?
  category        String?
  year            Int?
  make            String?
  model           String?
  vin             String?
  currentBid      Float?
  bidCount        Int?
  reservePrice    Float?
  city            String?
  state           String?
  zip             String?
  closingTime     DateTime?
  startTime       DateTime?
  status          String   @default("active")
  sourceUrl       String
  imageUrl        String?
  rawData         String?
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, sourceAuctionId, sourceLotId])
  @@index([source])
  @@index([state])
  @@index([closingTime])
  @@index([status])
}
